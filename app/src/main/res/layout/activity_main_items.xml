<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:layout_marginStart="4dp"
    android:layout_marginEnd="4dp"
    android:layout_marginBottom="4dp"
    android:padding="4dp"
    android:background="@drawable/rounded_edge_item"
    android:orientation="horizontal"
    >
    <RelativeLayout
        android:layout_width="match_parent"
        android:layout_height="match_parent">

        <TextView
            android:id="@+id/tvspoildate"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_centerVertical="true"
            />

        <TextView
            android:id="@+id/tvDaysLeftText"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="@string/tvDaysLeftText"
            android:layout_centerVertical="true"
            android:layout_centerInParent="true"
            android:textStyle="bold"
            android:paddingEnd="4dp"
            tools:ignore="RtlSymmetry" />

        <TextView
            android:id="@+id/tvDaysLeft"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_centerVertical="true"
            android:layout_toEndOf="@id/tvDaysLeftText"
            android:layout_toStartOf="@id/tvLocation"
            />

        <ImageView
            android:id="@+id/tvLocation"
            android:layout_width="36dp"
            android:layout_height="wrap_content"
            android:layout_gravity="end"
            android:layout_toStartOf="@id/deleteButton"
            android:layout_alignTop="@id/deleteButton"
            android:layout_alignBottom="@id/deleteButton" />
<!--            app:srcCompat="@mipmap/ic_pantry_round" -->
<!--            />-->

        <ImageView
            android:id="@+id/deleteButton"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_gravity="center"
            android:layout_alignParentEnd="true"
            android:src="@drawable/ic_menu_delete"
            />
    </RelativeLayout>

</LinearLayout>