<?xml version="1.0" encoding="utf-8"?>
<RelativeLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:tools="http://schemas.android.com/tools"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:id="@+id/productView"
    android:layout_width="fill_parent"
    android:layout_height="fill_parent"
    android:background="@color/colorBgMain">

    <LinearLayout
        android:id="@+id/imageLayout"
        android:layout_width="wrap_content"
        android:layout_height="400dp"
        android:padding="10dp"
        >

        <RelativeLayout
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:background="@drawable/rounded_edge_product"
            >

            <com.example.spoilalert.utils.RoundedImageView
                android:id="@+id/imageView"
                android:layout_alignParentTop="true"
                android:layout_width="fill_parent"
                android:layout_height="fill_parent"
                android:adjustViewBounds="true"
                android:padding="10dp"/>

            <ImageView
                android:id="@+id/refreshProductButton"
                android:layout_width="40dp"
                android:layout_height="40dp"
                android:layout_alignBottom="@id/imageView"
                android:layout_alignStart="@id/imageView"
                android:padding="5dp"
                android:layout_margin="10dp"
                android:clickable="true"
                android:src="@drawable/baseline_refresh_24"
                android:background="@drawable/circle_background"
                />

            <ImageView
                android:id="@+id/editImageButton"
                android:layout_width="40dp"
                android:layout_height="40dp"
                android:layout_alignBottom="@id/imageView"
                android:layout_alignEnd="@id/imageView"
                android:padding="5dp"
                android:layout_margin="10dp"
                android:clickable="true"
                android:src="@drawable/ic_edit"
                android:background="@drawable/circle_background"
                />

        </RelativeLayout>

    </LinearLayout>

    <RelativeLayout
        android:layout_width="fill_parent"
        android:layout_height="wrap_content"
        android:layout_below="@id/imageLayout"
        android:layout_margin="10dp"
        android:padding="10dp"
        android:background="@drawable/rounded_edge_product"
        >
        <ImageView
            android:id="@+id/NutriScore"
            android:layout_width="80dp"
            android:layout_height="80dp"
            android:layout_alignParentEnd="true"
            android:layout_alignParentTop="true"
            android:clickable="true"
            android:src="@raw/nutriscore_grey"
            />

        <TextView
            android:id="@+id/tvProductBrand"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_alignParentTop="true"
            android:layout_alignParentStart="true"
            android:layout_toStartOf="@id/NutriScore"
            android:textSize="32sp"
            android:textStyle="bold"
            android:gravity="start|center"
            android:textColor="@color/colorTitle"
            />

        <TextView
            android:id="@+id/tvProductName"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_below="@id/tvProductBrand"
            android:layout_alignParentStart="true"
            android:layout_toStartOf="@id/NutriScore"
            android:textSize="16sp"
            android:textStyle="bold"
            android:gravity="start|center"
            android:textColor="@color/colorTitle"
            />

        <TextView
            android:id="@+id/tvbarCode"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_alignParentTop="true"
            android:visibility="invisible"
            />
    </RelativeLayout>

</RelativeLayout>