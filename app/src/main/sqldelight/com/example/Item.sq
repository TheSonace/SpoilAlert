CREATE TABLE item_data (
  RecordKey INTEGER PRIMARY KEY AUTOINCREMENT,
  barCode TEXT NOT NULL,
  spoildate TEXT NOT NULL,
  scandatetime TEXT NOT NULL,
  removedatetime TEXT
);

CREATE INDEX item_data_barcode ON item_data(barCode);

selectAll:
SELECT *
FROM item_data;

insert:
INSERT INTO item_data (barCode, spoildate, scandatetime)
VALUES(?, ?, ?);

deleteAll:
DELETE
FROM item_data;

selectjson:
SELECT barCode, spoildate
FROM item_data
ORDER BY barCode, spoildate;